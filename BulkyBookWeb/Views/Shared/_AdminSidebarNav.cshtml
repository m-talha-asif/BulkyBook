@using BulkyBook.Utility
@{
    var isAdmin = User.IsInRole(SD.RoleAdmin);
}

<div class="admin-sidebar-nav d-flex flex-column h-100">

    <div>
        <p class="nav-section mb-1">Overview</p>
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link d-flex align-items-center gap-2">
            <i class="bi bi-graph-up"></i> Dashboard
        </a>

        <p class="nav-section mb-1">Commerce</p>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="nav-link d-flex align-items-center gap-2">
            <i class="bi bi-truck"></i> Orders
        </a>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="nav-link d-flex align-items-center gap-2">
            <i class="bi bi-book"></i> Products
        </a>
        <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="nav-link d-flex align-items-center gap-2">
            <i class="bi bi-tags"></i> Categories
        </a>

        @if (isAdmin)
        {
            <p class="nav-section mb-1">Management</p>
            <a asp-area="Admin" asp-controller="User" asp-action="Index" class="nav-link d-flex align-items-center gap-2">
                <i class="bi bi-people"></i> Users
            </a>
        }
    </div>

    <div class="border-top p-3 mt-auto" style="border-color: rgba(255,255,255,0.1) !important;">
        <div class="d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-person-circle" style="color: #94a3b8;"></i>
            <span class="small text-truncate flex-grow-1 text-white">@User.Identity?.Name</span>
        </div>
        <div class="d-flex gap-2">
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-light flex-grow-1">
                <i class="bi bi-shop"></i> Store
            </a>
            <form method="post" asp-area="Identity" asp-controller="Account" asp-action="Logout" class="m-0">
                <button type="submit" class="btn btn-sm btn-outline-danger" title="Logout">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </form>
        </div>
    </div>
</div>